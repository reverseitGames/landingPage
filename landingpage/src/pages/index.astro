---
import Layout from '../layouts/Layout.astro';
import robotArena from '../assets/mr.jpeg';
import humanArena from '../assets/human.webp';
---

<Layout>
	<main class="hero">
		<div class="backdrop-grid"></div>
		<div class="glow glow-one"></div>
		<div class="glow glow-two"></div>
		<div class="glow glow-three"></div>
		<div class="frame frame-top"></div>
		<div class="frame frame-bottom"></div>
		<section class="card">
			<p class="eyebrow">Reverse It Games Presents</p>
			<h1>Reverse It: Evil</h1>
		</section>
		<section class="arena" aria-label="Arena characters animation">
			<div class="slot slot-left">
				<figure class="poster robot">
					<img src={robotArena.src} alt="Robotic arena character" />
				</figure>
			</div>
			<div class="slot slot-right">
				<figure class="poster human">
					<img src={humanArena.src} alt="Human arena character" />
				</figure>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		min-height: 100vh;
		display: grid;
		place-items: center;
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at 50% 25%, rgba(81, 182, 255, 0.2), transparent 26%),
			radial-gradient(circle at 20% 80%, rgba(255, 74, 166, 0.18), transparent 24%),
			linear-gradient(180deg, #020409 0%, #060b14 45%, #020308 100%);
		padding: 2rem;
	}

	.backdrop-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 88%);
		opacity: 0.18;
	}

	.card {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 1.5rem 1.75rem 0.25rem;
		max-width: 1100px;
		margin-bottom: 0.25rem;
		backdrop-filter: blur(6px);
	}

	.arena {
		position: relative;
		width: min(1100px, 92vw);
		height: min(52vh, 560px);
		margin-top: 0.25rem;
		pointer-events: none;
		z-index: 1;
	}

	.slot {
		position: absolute;
		top: 50%;
		width: min(28vw, 320px);
		height: 100%;
		transform: translateY(-50%);
		will-change: left, right, opacity, filter;
	}

	.slot-left {
		left: 4%;
		animation: leftSlot 8s ease-in-out infinite;
	}

	.slot-right {
		right: 4%;
		animation: rightSlot 8s ease-in-out infinite;
	}

	.poster {
		position: absolute;
		inset: 50% auto auto 0;
		width: 100%;
		aspect-ratio: 4 / 5;
		margin: 0;
		border-radius: 28px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(8, 12, 22, 0.55);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.55),
			0 0 0 1px rgba(124, 247, 255, 0.08) inset;
		transform: translateY(-50%);
		opacity: 0.96;
		will-change: left, right, opacity;
	}

	.poster img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(0.9rem, 1.8vw, 1.1rem);
		letter-spacing: 0.42em;
		text-transform: uppercase;
		color: rgba(230, 245, 255, 0.76);
	}

	h1 {
		margin: 0;
		font-size: clamp(3.5rem, 11vw, 9rem);
		line-height: 0.95;
		font-weight: 900;
		letter-spacing: -0.09em;
		text-wrap: balance;
		background:
			linear-gradient(180deg, #ffffff 0%, #d9f8ff 24%, #89e7ff 48%, #ff9ae3 72%, #ffffff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		text-shadow:
			0 0 24px rgba(139, 231, 255, 0.12),
			0 0 64px rgba(255, 154, 227, 0.1);
		filter: saturate(1.1);
	}

	.glow {
		position: absolute;
		border-radius: 999px;
		filter: blur(90px);
		opacity: 0.75;
		pointer-events: none;
	}

	.glow-one {
		width: 28rem;
		height: 28rem;
		background: rgba(0, 194, 255, 0.16);
		top: 12%;
		left: 12%;
	}

	.glow-two {
		width: 24rem;
		height: 24rem;
		background: rgba(255, 86, 181, 0.18);
		bottom: 10%;
		right: 8%;
	}

	.glow-three {
		width: 16rem;
		height: 16rem;
		background: rgba(185, 255, 102, 0.12);
		top: 44%;
		right: 22%;
	}

	.frame {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: min(78vw, 1120px);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(124, 247, 255, 0.85), rgba(255, 255, 255, 0.2), rgba(255, 124, 217, 0.8), transparent);
		opacity: 0.7;
	}

	.frame-top {
		top: 11%;
	}

	.frame-bottom {
		bottom: 11%;
	}

	@media (max-width: 900px) {
		.arena {
			height: min(48vh, 500px);
		}

		.slot {
			width: min(35vw, 220px);
		}

		.poster {
			width: 100%;
		}
	}

	@media (max-width: 700px) {
		.arena {
			height: auto;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
		}

		.slot {
			position: relative;
			top: auto;
			left: auto;
			right: auto;
			width: 100%;
			height: auto;
			transform: none;
		}

		.poster {
			position: relative;
			inset: auto;
			transform: none;
		}
	}

	@keyframes leftSlot {
		0%, 30% {
			left: 4%;
			opacity: 1;
			filter: saturate(1);
		}

		35% {
			left: 20%;
			opacity: 0.98;
			filter: saturate(1.2) brightness(1.08);
		}

		52%, 100% {
			left: calc(100% - min(28vw, 320px) - 4%);
			opacity: 1;
			filter: saturate(1);
		}
	}

	@keyframes rightSlot {
		0%, 30% {
			right: 4%;
			opacity: 1;
			filter: saturate(1);
		}

		35% {
			right: 20%;
			opacity: 0.98;
			filter: saturate(1.1) brightness(1.02);
		}

		52%, 100% {
			right: calc(100% - min(28vw, 320px) - 4%);
			opacity: 1;
			filter: saturate(1);
		}
	}
</style>
