---
import Layout from '../layouts/Layout.astro';
import robotArena from '../assets/mr.jpeg';
import humanArena from '../assets/human.webp';
---

<Layout>
	<main class="hero">
		<div class="backdrop-grid"></div>
		<div class="glow glow-one"></div>
		<div class="glow glow-two"></div>
		<div class="glow glow-three"></div>
		<div class="frame frame-top"></div>
		<div class="frame frame-bottom"></div>
		<section class="card">
			<p class="eyebrow">Reverse It Games Presents</p>
			<h1>Reverse It: Evil</h1>
			<div class="hero-cta" aria-label="Primary signup call to action">
				<div class="signup-copy">
					<p class="signup-label">Get updates</p>
					<h2>Join the Reverse It: Evil list</h2>
					<p>
						Sign up for launch news, playtest invites, and release updates in the signup overlay.
					</p>
				</div>
				<button class="cta-button" type="button" data-open-signup>Open signup form</button>
			</div>
		</section>
		<section class="arena" aria-label="Arena characters animation">
			<div class="slot slot-left">
				<figure class="poster robot">
					<img src={robotArena.src} alt="Robotic arena character" />
				</figure>
			</div>
			<div class="slot slot-right">
				<figure class="poster human">
					<img src={humanArena.src} alt="Human arena character" />
				</figure>
			</div>
		</section>
		<section class="description-panel" aria-label="Game description">
			<span class="corner corner-tl"></span>
			<span class="corner corner-tr"></span>
			<span class="corner corner-bl"></span>
			<span class="corner corner-br"></span>
			<h2>About the Game</h2>
			<p>
				Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt
				ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation
				ullamco laboris nisi ut aliquip ex ea commodo consequat.
			</p>
		</section>
	</main>

	<div class="signup-overlay" data-signup-overlay hidden>
		<div class="signup-backdrop" data-close-signup></div>
		<section class="signup-modal" role="dialog" aria-modal="true" aria-labelledby="signup-title">
			<button class="signup-close" type="button" aria-label="Close signup form" data-close-signup>
				×
			</button>
			<div class="signup-copy modal-copy">
				<p class="signup-label">Get updates</p>
				<h2 id="signup-title">Join the Reverse It: Evil list</h2>
				<p>
					Sign up for launch news, playtest invites, and release updates.
				</p>
			</div>
			<div class="kit-embed kit-embed-modal" aria-live="polite">
				<script async data-uid="e6a35db5c8" src="https://reverse-it-games.kit.com/e6a35db5c8/index.js"></script>
			</div>
		</section>
	</div>

	<script is:inline>
		const overlay = document.querySelector('[data-signup-overlay]');
		const openButtons = document.querySelectorAll('[data-open-signup]');
		const closeButtons = document.querySelectorAll('[data-close-signup]');

		const openOverlay = () => {
			if (!overlay) return;
			overlay.hidden = false;
			document.body.classList.add('signup-open');
		};

		const closeOverlay = () => {
			if (!overlay) return;
			overlay.hidden = true;
			document.body.classList.remove('signup-open');
		};

		openButtons.forEach((button) => button.addEventListener('click', openOverlay));
		closeButtons.forEach((button) => button.addEventListener('click', closeOverlay));

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !overlay?.hidden) closeOverlay();
		});
	</script>
</Layout>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at 50% 25%, rgba(81, 182, 255, 0.2), transparent 26%),
			radial-gradient(circle at 20% 80%, rgba(255, 74, 166, 0.18), transparent 24%),
			linear-gradient(180deg, #020409 0%, #060b14 45%, #020308 100%);
		padding: 2rem;
	}

	.backdrop-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 88%);
		opacity: 0.18;
	}

	.card {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 1.5rem 1.75rem 0.25rem;
		max-width: 1100px;
		margin-bottom: 1rem;
		backdrop-filter: blur(6px);
	}

	.hero-cta {
		position: relative;
		margin: 1.25rem auto 0;
		padding: 1.25rem 1.25rem 1.35rem;
		border-radius: 16px;
		border: 1px solid rgba(255, 154, 227, 0.28);
		background:
			linear-gradient(180deg, rgba(10, 12, 22, 0.96), rgba(5, 7, 14, 0.96)),
			radial-gradient(circle at top center, rgba(255, 154, 227, 0.14), transparent 48%);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.35),
			0 0 0 1px rgba(255, 255, 255, 0.03) inset;
		backdrop-filter: blur(10px);
		overflow: hidden;
	}

	.hero-cta::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, transparent 0%, rgba(255, 154, 227, 0.07) 50%, transparent 100%),
			repeating-linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.03) 0,
				rgba(255, 255, 255, 0.03) 1px,
				transparent 1px,
				transparent 7px
			);
		pointer-events: none;
		opacity: 0.6;
	}

	.hero-cta .signup-copy,
	.hero-cta .kit-embed {
		position: relative;
		z-index: 1;
	}

	.hero-cta .signup-copy {
		margin-bottom: 1rem;
	}

	.hero-cta .signup-label {
		margin: 0 0 0.5rem;
		font-size: 0.78rem;
		letter-spacing: 0.34em;
		text-transform: uppercase;
		color: rgba(255, 226, 243, 0.7);
	}

	.hero-cta h2 {
		margin: 0 0 0.55rem;
		font-size: clamp(1rem, 1.8vw, 1.4rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #fff1f8;
	}

	.hero-cta p {
		margin: 0;
		font-size: clamp(0.96rem, 1.35vw, 1.05rem);
		line-height: 1.6;
		color: rgba(246, 250, 255, 0.9);
	}

	.cta-button {
		position: relative;
		z-index: 1;
		margin-top: 1rem;
		padding: 0.9rem 1.2rem;
		border: 1px solid rgba(124, 247, 255, 0.38);
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(124, 247, 255, 0.16), rgba(255, 154, 227, 0.12));
		color: #f6fbff;
		font: inherit;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
	}

	.cta-button:hover {
		filter: brightness(1.08);
	}

	.arena {
		position: relative;
		width: min(960px, 92vw);
		height: min(52vh, 560px);
		margin-top: 0.15rem;
		pointer-events: none;
		z-index: 1;
		--arena-span: calc(min(960px, 92vw) - min(28vw, 320px) - 8vw);
	}

	.description-panel {
		position: relative;
		z-index: 1;
		width: min(960px, 92vw);
		margin-top: 1rem;
		margin-bottom: 2rem;
		padding: 1.75rem 1.75rem 1.85rem;
		border-radius: 14px;
		border: 1px solid rgba(124, 247, 255, 0.28);
		background:
			linear-gradient(180deg, rgba(8, 13, 22, 0.98), rgba(3, 6, 12, 0.98)),
			radial-gradient(circle at top left, rgba(124, 247, 255, 0.12), transparent 38%);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.35),
			0 0 0 1px rgba(255, 255, 255, 0.03) inset;
		backdrop-filter: blur(10px);
		overflow: hidden;
	}

	.description-panel::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, transparent 0%, rgba(124, 247, 255, 0.04) 50%, transparent 100%),
			repeating-linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.03) 0,
				rgba(255, 255, 255, 0.03) 1px,
				transparent 1px,
				transparent 6px
			);
		pointer-events: none;
		opacity: 0.65;
	}

	.corner {
		position: absolute;
		width: 22px;
		height: 22px;
		border-color: rgba(124, 247, 255, 0.8);
		pointer-events: none;
		z-index: 1;
	}

	.corner-tl {
		top: 10px;
		left: 10px;
		border-top: 2px solid;
		border-left: 2px solid;
	}

	.corner-tr {
		top: 10px;
		right: 10px;
		border-top: 2px solid;
		border-right: 2px solid;
	}

	.corner-bl {
		bottom: 10px;
		left: 10px;
		border-bottom: 2px solid;
		border-left: 2px solid;
	}

	.corner-br {
		bottom: 10px;
		right: 10px;
		border-bottom: 2px solid;
		border-right: 2px solid;
	}

	.description-panel h2 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.2rem, 2.2vw, 1.8rem);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #d7f6ff;
		position: relative;
		z-index: 1;
	}

	.description-panel p {
		margin: 0;
		max-width: 70ch;
		font-size: clamp(1rem, 1.5vw, 1.2rem);
		line-height: 1.7;
		color: rgba(246, 250, 255, 0.94);
		position: relative;
		z-index: 1;
	}

	.kit-embed {
		min-height: 140px;
		width: 100%;
	}

	.signup-overlay {
		position: fixed;
		inset: 0;
		z-index: 50;
		display: grid;
		place-items: center;
		padding: 1rem;
	}

	.signup-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(1, 3, 7, 0.78);
		backdrop-filter: blur(10px);
	}

	.signup-modal {
		position: relative;
		z-index: 1;
		width: min(720px, 94vw);
		max-height: min(88vh, 920px);
		overflow: auto;
		padding: 1.5rem;
		border-radius: 20px;
		border: 1px solid rgba(255, 154, 227, 0.24);
		background:
			linear-gradient(180deg, rgba(8, 11, 19, 0.98), rgba(4, 6, 11, 0.98)),
			radial-gradient(circle at top center, rgba(255, 154, 227, 0.14), transparent 45%);
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
	}

	.signup-close {
		position: absolute;
		top: 0.85rem;
		right: 0.9rem;
		width: 2.4rem;
		height: 2.4rem;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.04);
		color: #fff;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
	}

	body.signup-open {
		overflow: hidden;
	}

	.kit-embed-modal {
		min-height: 280px;
	}

	.slot {
		position: absolute;
		top: 50%;
		width: min(28vw, 320px);
		height: 100%;
		transform: translateY(-50%);
		will-change: transform, opacity, filter;
	}

	.slot-left {
		left: 4%;
		animation: leftSlot 10s ease-in-out infinite;
	}

	.slot-right {
		right: 4%;
		animation: rightSlot 10s ease-in-out infinite;
	}

	.poster {
		position: absolute;
		inset: 50% auto auto 0;
		width: 100%;
		aspect-ratio: 4 / 5;
		margin: 0;
		border-radius: 28px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(8, 12, 22, 0.55);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.55),
			0 0 0 1px rgba(124, 247, 255, 0.08) inset;
		transform: translateY(-50%);
		opacity: 0.96;
		will-change: transform, opacity;
	}

	.poster img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(0.9rem, 1.8vw, 1.1rem);
		letter-spacing: 0.42em;
		text-transform: uppercase;
		color: rgba(230, 245, 255, 0.76);
	}

	h1 {
		margin: 0;
		font-size: clamp(3.5rem, 11vw, 9rem);
		line-height: 0.95;
		font-weight: 900;
		letter-spacing: -0.09em;
		text-wrap: balance;
		background:
			linear-gradient(180deg, #ffffff 0%, #d9f8ff 24%, #89e7ff 48%, #ff9ae3 72%, #ffffff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		text-shadow:
			0 0 24px rgba(139, 231, 255, 0.12),
			0 0 64px rgba(255, 154, 227, 0.1);
		filter: saturate(1.1);
	}

	.glow {
		position: absolute;
		border-radius: 999px;
		filter: blur(90px);
		opacity: 0.75;
		pointer-events: none;
	}

	.glow-one {
		width: 28rem;
		height: 28rem;
		background: rgba(0, 194, 255, 0.16);
		top: 12%;
		left: 12%;
	}

	.glow-two {
		width: 24rem;
		height: 24rem;
		background: rgba(255, 86, 181, 0.18);
		bottom: 10%;
		right: 8%;
	}

	.glow-three {
		width: 16rem;
		height: 16rem;
		background: rgba(185, 255, 102, 0.12);
		top: 44%;
		right: 22%;
	}

	.frame {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		width: min(78vw, 1120px);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(124, 247, 255, 0.85), rgba(255, 255, 255, 0.2), rgba(255, 124, 217, 0.8), transparent);
		opacity: 0.7;
	}

	.frame-top {
		top: 11%;
	}

	.frame-bottom {
		bottom: 11%;
	}

	@media (max-width: 900px) {
		.arena {
			height: min(48vh, 500px);
			--arena-span: calc(min(960px, 92vw) - min(35vw, 220px) - 8vw);
		}

		.description-panel {
			margin-top: 0.75rem;
		}

		.slot {
			width: min(35vw, 220px);
		}

		.poster {
			width: 100%;
		}
	}

	@media (max-width: 700px) {
		.arena {
			height: auto;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
		}

		.slot {
			position: relative;
			top: auto;
			left: auto;
			right: auto;
			width: 100%;
			height: auto;
			transform: none;
		}

		.poster {
			position: relative;
			inset: auto;
			transform: none;
		}

		.description-panel {
			padding: 1.25rem 1.25rem 1.4rem;
		}

		.hero-cta {
			padding: 1rem 1rem 1.1rem;
		}

		.signup-modal {
			padding: 1.1rem;
		}
	}

	@keyframes leftSlot {
		0% {
			transform: translateY(-50%) translateX(0);
			opacity: 1;
			filter: saturate(1);
		}

		30% {
			transform: translateY(-50%) translateX(calc(var(--arena-span) * 0.24));
			opacity: 0.98;
			filter: saturate(1.2) brightness(1.08);
		}

		50% {
			transform: translateY(-50%) translateX(var(--arena-span));
			opacity: 1;
			filter: saturate(1);
		}

		70% {
			transform: translateY(-50%) translateX(calc(var(--arena-span) * 0.24));
			opacity: 0.98;
			filter: saturate(1.2) brightness(1.08);
		}

		100% {
			transform: translateY(-50%) translateX(0);
			opacity: 1;
			filter: saturate(1);
		}
	}

	@keyframes rightSlot {
		0% {
			transform: translateY(-50%) translateX(0);
			opacity: 1;
			filter: saturate(1);
		}

		30% {
			transform: translateY(-50%) translateX(calc(var(--arena-span) * -0.24));
			opacity: 0.98;
			filter: saturate(1.1) brightness(1.02);
		}

		50% {
			transform: translateY(-50%) translateX(calc(var(--arena-span) * -1));
			opacity: 1;
			filter: saturate(1);
		}

		70% {
			transform: translateY(-50%) translateX(calc(var(--arena-span) * -0.24));
			opacity: 0.98;
			filter: saturate(1.1) brightness(1.02);
		}

		100% {
			transform: translateY(-50%) translateX(0);
			opacity: 1;
			filter: saturate(1);
		}
	}
</style>
